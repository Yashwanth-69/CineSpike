# ── TMDB API (optional, for fetching movie posters) ────────────────────────
# Get a free key at: https://www.themoviedb.org/settings/api
# If left blank, letter-avatar placeholders are used instead.
TMDB_API_KEY=

# ── Groq API (for AI campaign generation) ──────────────────────────────────
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional. Defaults to llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# ── Flask Secret Key ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production

# ── Frontend / Deployment ───────────────────────────────────────────────────
# Set this to your Vercel domain so the split frontend can call the backend.
FRONTEND_ORIGIN=

# Use absolute paths on Render when attaching a persistent disk, for example:
# /var/data/uploads, /var/data/cinespike.db, /var/data/chroma_db, /var/data/data
UPLOAD_FOLDER=uploads
DB_PATH=cinespike.db
CHROMA_PATH=./chroma_db
DATA_DIR=./data
